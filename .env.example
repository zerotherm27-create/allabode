# Supabase — copy to .env.local and fill in (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service role key (NEVER expose to the client / commit).
# Optional: only needed for privileged admin operations that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — server-only, used for AI receipt extraction + SOA summaries.
# Never prefix with NEXT_PUBLIC. AI features degrade to manual entry if unset.
OPENAI_API_KEY=
# Optional override; defaults to gpt-4.1-mini.
OPENAI_RECEIPT_MODEL=

# Google Drive archive — server-only. SOAs auto-archive to Drive on publish.
# Leave unset to skip Drive archiving (publish still works normally).
# GOOGLE_SERVICE_ACCOUNT_KEY — full JSON key file content (stringified, single line)
GOOGLE_SERVICE_ACCOUNT_KEY=
# GOOGLE_DRIVE_ROOT_FOLDER_ID — ID from the Drive folder URL (.../folders/<ID>)
GOOGLE_DRIVE_ROOT_FOLDER_ID=
